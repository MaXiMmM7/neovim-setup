{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GitLab CI Configuration",
  "description": "Local fallback schema for .gitlab-ci.yml. The upstream GitLab schema URL referenced by SchemaStore currently returns HTTP 403 from this machine, so yamlls cannot download it reliably. This permissive local schema prevents false schema-load diagnostics while still allowing GitLab-specific tags and regular YAML validation in Neovim.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "stages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "default": {
      "type": "object",
      "additionalProperties": true
    },
    "variables": {
      "type": "object",
      "additionalProperties": true
    },
    "workflow": {
      "type": "object",
      "additionalProperties": true
    },
    "include": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          }
        }
      ]
    },
    "image": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "services": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "additionalProperties": true
          }
        ]
      }
    },
    "before_script": {
      "$ref": "#/definitions/scriptLike"
    },
    "script": {
      "$ref": "#/definitions/scriptLike"
    },
    "after_script": {
      "$ref": "#/definitions/scriptLike"
    },
    "cache": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      ]
    }
  },
  "patternProperties": {
    "^\\..+": {
      "type": "object",
      "additionalProperties": true
    },
    "^[A-Za-z0-9_:-]+$": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "definitions": {
    "scriptLike": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          }
        }
      ]
    }
  }
}
